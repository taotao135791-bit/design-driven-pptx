title: Comprehensive Test
size: [1280, 720]
theme:
  colors:
    primary: "#E85D5D"
    background: "#F5F0E8"
    ink: "#1A1A1A"
    text: "#6B6B6B"
    white: "#FFFFFF"
  textStyles:
    heroTitle:
      fontSize: 64
      color: "$ink"
      fontFamily: "Bebas Neue"
    body:
      fontSize: 18
      color: "$text"
      fontFamily: "Inter"
  tableStyles:
    default:
      fontSize: 15
      fontFamily: "Inter"
      headerFill: "$primary"
      headerColor: "$white"
      bodyFill: ["$white", "$background"]
      bodyColor: "$ink"
pages:
  - pages/p1_cover.page
  - pages/p2_budget.page
  - pages/p3_trend.page
  - pages/p4_compare.page
  - pages/p5_timeline.page
  - pages/p6_table.page
