pageType: final
elements:
  - elementType: shape
    shapeName: rect
    bounds: [0, 0, 1280, 720]
    layer: -1
    fill:
      type: solid
      color: "$surface"
  - elementType: shape
    shapeName: rect
    bounds: [0, 0, 1280, 720]
    layer: -1
    fill:
      type: gradient
      gradient:
        type: linear
        angle: 135
        stops:
          - color: "$background"
            position: 0
          - color: "$surfaceAlt"
            position: 1
  - elementType: text
    bounds: [240, 160, 800, 80]
    layer: 1
    styleRef: "$heroTitle"
    content:
      text: |
        <p>Thank You</p>
  - elementType: shape
    shapeName: rect
    bounds: [560, 260, 160, 2]
    layer: 2
    fill:
      type: solid
      color: "$primary"
  - elementType: text
    bounds: [240, 290, 800, 40]
    layer: 1
    styleRef: "$body"
    content:
      text: |
        <p>Design-driven PPTX conversion pipeline validated successfully.</p>
  - elementType: text
    bounds: [240, 360, 800, 80]
    layer: 1
    styleRef: "$bodySm"
    content:
      text: |
        <p><span style="color:#8a8476">Tests passed: Charts · Tables · Timelines · Shapes · Rich Text · Animations · Shadows · Gradients</span></p>
  - elementType: text
    bounds: [240, 460, 800, 80]
    layer: 1
    styleRef: "$body"
    content:
      text: |
        <p>Every component from theme resolution to chart rendering has been validated across 8 comprehensive test pages covering all major element types.</p>
  - elementType: shape
    shapeName: ellipse
    bounds: [1140, 120, 60, 60]
    layer: 0
    fill:
      type: solid
      color: "$primary"
    opacity: 0.15
  - elementType: shape
    shapeName: rect
    bounds: [200, 580, 80, 3]
    layer: 2
    fill:
      type: solid
      color: "$border"
    rotation: -15
    animation:
      type: fade
      trigger: withPrevious
      duration: 1000
